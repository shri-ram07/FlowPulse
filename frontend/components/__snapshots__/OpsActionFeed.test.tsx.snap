exports[`OpsActionFeed > renders the login-needed state when no token is supplied 1`] = `"<div class="panel" style="flex:1;min-height:0"><div class="panel-head"><h2>Ops Agent</h2><span class="status-chip">JSON action plan</span></div><div class="info-banner" style="margin-bottom:10px"><span aria-hidden="true">💡</span><span>Drag <b>Chaos</b> to force congestion, then click <b>Propose Actions</b>. Apply any action to dispatch it live — the map reacts on the next tick.</span></div><div style="display:flex;gap:8px;margin-bottom:8px"><button class="btn" disabled="">Propose Actions</button></div><label>Chaos injection: <b>0<!-- -->%</b><input class="slider" type="range" min="0" max="100" disabled="" value="0"/></label></div><div class="toast-stack" role="status" aria-live="polite"></div>"`;
