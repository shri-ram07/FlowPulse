// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`FlowScoreGauge > matches snapshot for a healthy venue 1`] = `"<div class="panel" style="padding:14px"><h2>Stadium Pulse</h2><div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px"><div><div class="gauge-num"><span class="score-pill good" style="font-size:22px;padding:4px 14px">88</span></div><div class="gauge-sub">Average Flow Score</div></div><div><div class="gauge-num" style="color:var(--muted)">0</div><div class="gauge-sub">Critical zones</div></div><div><div class="gauge-num" style="color:var(--muted)">0</div><div class="gauge-sub">Congested</div></div></div><div class="meta" style="margin-top:8px">Higher is healthier. Any red cluster on the map is where attention is needed.</div></div>"`;
