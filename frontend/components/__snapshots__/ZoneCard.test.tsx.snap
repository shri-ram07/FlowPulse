exports[`ZoneCard > matches the snapshot for a watch-band zone 1`] = `"<div class="card"><div style="display:flex;justify-content:space-between;align-items:center;gap:10px"><div><h3>Food Court 1</h3><div class="meta">Food court<!-- --> · <!-- -->building</div></div><span class="score-pill ok">72<!-- -->/100</span></div><div style="margin-top:8px;height:6px;background:var(--panel-soft);border-radius:999px;overflow:hidden;border:1px solid var(--border)" aria-label="Occupancy 55%"><div style="width:55%;height:100%;background:#d97706"></div></div><div class="meta-row"><span><b>100</b>/<!-- -->180<!-- --> people</span><span><b>6.3</b> min wait</span><span>trend <b>rising</b></span></div><div class="meta-row"><span>in <b>8.2</b>/min</span><span>out <b>4.1</b>/min</span><span>density <b>55<!-- -->%</b></span></div></div>"`;
