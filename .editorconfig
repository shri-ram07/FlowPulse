# EditorConfig — cross-IDE consistency (https://editorconfig.org/)
# Tells VS Code, PyCharm, Vim, etc. to use the same indent / encoding / EOL.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{py,pyi}]
indent_size = 4
max_line_length = 110

[*.{js,jsx,ts,tsx,mjs,cjs}]
indent_size = 2
max_line_length = 100

[*.{json,yaml,yml,toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[Makefile]
indent_style = tab
