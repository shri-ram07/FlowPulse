# Copy to .env and fill in as needed. All variables are OPTIONAL — the demo
# runs end-to-end without any of them (agents fall back to deterministic
# reasoning, JWT uses a dev secret, FCM runs dry-run, Cloud Trace no-ops).

# ---- JWT signing secret for staff auth -------------------------------
# Generate with: py -3 -c "import secrets; print(secrets.token_urlsafe(48))"
FLOWPULSE_JWT_SECRET=dev-secret-change-me

# ---- Google AI / Gemini via ADK --------------------------------------
# Free key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ---- FCM HTTP v1 (service-account JSON) ------------------------------
# Absolute path to a service-account key file. The legacy FCM Server Key
# has been deprecated by Google — use this instead.
# Firebase Console → Project settings → Service accounts → Generate new
# private key. Save the JSON OUTSIDE the repo.
GOOGLE_APPLICATION_CREDENTIALS=

# ---- Cloud Trace target project --------------------------------------
# Your GCP project ID. Enables OpenTelemetry spans export.
GOOGLE_CLOUD_PROJECT=

# ---- Log verbosity ---------------------------------------------------
FLOWPULSE_LOG_LEVEL=INFO
